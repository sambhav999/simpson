generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  walletAddress         String                @id @map("_id")
  createdAt             DateTime              @default(now()) @map("created_at")
  currentStreak         Int                   @default(0) @map("current_streak")
  highestStreak         Int                   @default(0) @map("highest_streak")
  lastTradeDate         DateTime?             @map("last_trade_date")
  avatarUrl             String?               @map("avatar_url")
  username              String?               @unique
  bio                   String?
  updatedAt             DateTime              @default(now()) @updatedAt @map("updated_at")
  xpTotal               Int                   @default(0) @map("xp_total")
  aiPredictions         AIPrediction[]
  attributionsAsCreator Attribution[]         @relation("CreatorAttributions")
  attributionsAsUser    Attribution[]         @relation("UserAttributions")
  comments              Comment[]
  creatorMarkets        CreatorMarket[]
  following             Follow[]              @relation("Followers")
  followers             Follow[]              @relation("Following")
  leaderboards          Leaderboard[]
  memeCards             MemeCard[]
  points                Points?
  pointsLedger          PointsLedger[]
  positions             Position[]
  trades                Trade[]
  userDailyPredictions  UserDailyPrediction[]
  xpTransactions        XPTransaction[]

  @@map("users")
}

model Market {
  id                 String              @id @default(auto()) @map("_id") @db.ObjectId
  title              String
  description        String              @default("")
  yesTokenMint       String              @map("yes_token_mint")
  noTokenMint        String              @map("no_token_mint")
  expiry             DateTime?
  status             String              @default("active")
  category           String              @default("general")
  externalId         String?             @unique @map("external_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  divergenceScore    Float               @default(0) @map("divergence_score")
  oraclePrice        Float?              @map("oracle_price")
  image              String?             @map("image_url")
  closesAt           DateTime?           @map("closes_at")
  liquidity          Float?              @default(0)
  noPrice            Float?              @map("no_price")
  resolution         String?
  resolved           Boolean             @default(false)
  source             String              @default("polymarket")
  sourceUrl          String?             @map("source_url")
  volume             Float?              @default(0)
  yesPrice           Float?              @map("yes_price")
  aiPredictions      AIPrediction[]
  attributions       Attribution[]
  comments           Comment[]
  creatorMarkets     CreatorMarket[]
  dailyBattleMarkets DailyBattleMarket[]
  memeCards          MemeCard[]
  positions          Position[]
  protocolRevenues   ProtocolRevenue[]
  trades             Trade[]

  @@index([status])
  @@index([category])
  @@index([source])
  @@index([yesTokenMint])
  @@index([noTokenMint])
  @@index([closesAt])
  @@index([volume])
  @@index([liquidity])
  @@map("markets")
}

model Position {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  walletAddress     String   @map("wallet_address")
  marketId          String   @map("market_id") @db.ObjectId
  tokenMint         String   @map("token_mint")
  amount            Float    @default(0)
  averageEntryPrice Float    @default(0) @map("average_entry_price")
  realizedPnl       Float    @default(0) @map("realized_pnl")
  updatedAt         DateTime @updatedAt @map("updated_at")
  entryOdds         Float?   @map("entry_odds")
  predictedAt       DateTime @default(now()) @map("predicted_at")
  side              String?
  status            String   @default("ACTIVE")
  market            Market   @relation(fields: [marketId], references: [id])
  user              User     @relation(fields: [walletAddress], references: [walletAddress])

  @@unique([walletAddress, marketId, tokenMint])
  @@index([walletAddress])
  @@index([marketId])
  @@index([status])
  @@map("positions")
}

model Trade {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  walletAddress String   @map("wallet_address")
  marketId      String   @map("market_id") @db.ObjectId
  tokenMint     String   @map("token_mint")
  side          String
  price         Float
  amount        Float
  fee           Float    @default(0)
  signature     String   @unique
  timestamp     DateTime
  createdAt     DateTime @default(now()) @map("created_at")
  market        Market   @relation(fields: [marketId], references: [id])
  user          User     @relation(fields: [walletAddress], references: [walletAddress])

  @@index([walletAddress])
  @@index([marketId])
  @@index([timestamp])
  @@map("trades")
}

model AIPrediction {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  marketId          String   @map("market_id") @db.ObjectId
  prediction        String
  confidence        Int
  summaryCommentary String?  @map("summary_commentary")
  bullishCommentary String?  @map("bullish_commentary")
  bearishCommentary String?  @map("bearish_commentary")
  commentary        String?
  featured          Boolean  @default(false)
  featuredRank      Int?     @map("featured_rank")
  resolved          Boolean  @default(false)
  result            String   @default("PENDING")
  createdAt         DateTime @default(now()) @map("created_at")
  createdBy         String?  @map("created_by")
  creator           User?    @relation(fields: [createdBy], references: [walletAddress])
  market            Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId])
  @@index([resolved])
  @@index([featured])
  @@map("ai_predictions")
}

model CreatorMarket {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  creatorId    String   @map("creator_id")
  marketId     String   @map("market_id") @db.ObjectId
  caption      String
  referralCode String   @unique @map("referral_code")
  hostedAt     DateTime @default(now()) @map("hosted_at")
  creator      User     @relation(fields: [creatorId], references: [walletAddress], onDelete: Cascade)
  market       Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([marketId])
  @@map("creator_markets")
}

model Attribution {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  creatorId     String?  @map("creator_id")
  userId        String?  @map("user_id")
  marketId      String   @map("market_id") @db.ObjectId
  referralCode  String?  @map("referral_code")
  clickedAt     DateTime @default(now()) @map("clicked_at")
  converted     Boolean  @default(false)
  tradePlatform String?  @map("trade_platform")
  creator       User?    @relation("CreatorAttributions", fields: [creatorId], references: [walletAddress])
  market        Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user          User?    @relation("UserAttributions", fields: [userId], references: [walletAddress])

  @@index([creatorId])
  @@index([referralCode])
  @@index([clickedAt])
  @@map("attributions")
}

model Comment {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @map("user_id")
  marketId  String    @map("market_id") @db.ObjectId
  parentId  String?   @map("parent_id") @db.ObjectId
  text      String
  upvotes   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  market    Market    @relation(fields: [marketId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   Comment[] @relation("CommentReplies")
  user      User      @relation(fields: [userId], references: [walletAddress], onDelete: Cascade)

  @@index([marketId])
  @@index([parentId])
  @@index([createdAt])
  @@map("comments")
}

model Follow {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")
  follower    User     @relation("Followers", fields: [followerId], references: [walletAddress], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [walletAddress], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

model MemeCard {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String    @map("user_id")
  marketId   String    @map("market_id") @db.ObjectId
  template   String
  imageUrl   String    @map("image_url")
  trackingId String    @unique @map("tracking_id")
  shares     Int       @default(0)
  clicks     Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime? @map("expires_at")
  market     Market    @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [walletAddress], onDelete: Cascade)

  @@index([userId])
  @@map("meme_cards")
}

model XPTransaction {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  walletAddress String   @map("wallet_address")
  amount        Int
  reason        String
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  user          User     @relation(fields: [walletAddress], references: [walletAddress], onDelete: Cascade)

  @@index([walletAddress])
  @@index([createdAt])
  @@map("xp_transactions")
}

model DailyBattle {
  id        String              @id @default(auto()) @map("_id") @db.ObjectId
  date      DateTime            @unique
  status    String              @default("active")
  createdAt DateTime            @default(now()) @map("created_at")
  markets   DailyBattleMarket[]

  @@index([status])
  @@map("daily_battles")
}

model DailyBattleMarket {
  id                String                @id @default(auto()) @map("_id") @db.ObjectId
  dailyBattleId     String                @map("daily_battle_id") @db.ObjectId
  marketId          String                @map("market_id") @db.ObjectId
  position          Int
  homerPrediction   String                @map("homer_prediction")
  homerConfidence   Int                   @map("homer_confidence")
  homerCommentary   String?               @map("homer_commentary")
  bullishCommentary String?               @map("bullish_commentary")
  bearishCommentary String?               @map("bearish_commentary")
  result            String                @default("PENDING")
  createdAt         DateTime              @default(now()) @map("created_at")
  dailyBattle       DailyBattle           @relation(fields: [dailyBattleId], references: [id], onDelete: Cascade)
  market            Market                @relation(fields: [marketId], references: [id], onDelete: Cascade)
  userPredictions   UserDailyPrediction[]

  @@unique([dailyBattleId, position])
  @@index([dailyBattleId])
  @@index([result])
  @@map("daily_battle_markets")
}

model UserDailyPrediction {
  id                  String            @id @default(auto()) @map("_id") @db.ObjectId
  userId              String            @map("user_id")
  dailyBattleMarketId String            @map("daily_battle_market_id") @db.ObjectId
  prediction          String
  result              String            @default("PENDING")
  createdAt           DateTime          @default(now()) @map("created_at")
  dailyBattleMarket   DailyBattleMarket @relation(fields: [dailyBattleMarketId], references: [id], onDelete: Cascade)
  user                User              @relation(fields: [userId], references: [walletAddress], onDelete: Cascade)

  @@unique([userId, dailyBattleMarketId])
  @@index([userId])
  @@index([result])
  @@map("user_daily_predictions")
}

model Leaderboard {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  walletAddress String   @map("wallet_address")
  totalVolume   Float    @default(0) @map("total_volume")
  totalPnl      Float    @default(0) @map("total_pnl")
  winRate       Float    @default(0) @map("win_rate")
  tradeCount    Int      @default(0) @map("trade_count")
  updatedAt     DateTime @updatedAt @map("updated_at")
  period        String   @default("ALL_TIME")
  user          User     @relation(fields: [walletAddress], references: [walletAddress])

  @@unique([walletAddress, period])
  @@index([totalPnl])
  @@index([totalVolume])
  @@map("leaderboard")
}

model ProtocolRevenue {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  marketId    String   @map("market_id") @db.ObjectId
  amount      Float    @default(0)
  assetMint   String   @map("asset_mint")
  collectedAt DateTime @default(now()) @map("collected_at")
  market      Market   @relation(fields: [marketId], references: [id])

  @@index([marketId])
  @@index([assetMint])
  @@map("protocol_revenue")
}

model Points {
  walletAddress String   @id @map("_id")
  balance       Int      @default(0)
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [walletAddress], references: [walletAddress])

  @@index([balance])
  @@map("points")
}

model PointsLedger {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  walletAddress String   @map("wallet_address")
  amount        Int
  reason        String
  createdAt     DateTime @default(now()) @map("created_at")
  user          User     @relation(fields: [walletAddress], references: [walletAddress])

  @@index([walletAddress])
  @@map("points_ledger")
}

model IndexerState {
  id            String   @id @map("_id") @default("singleton")
  lastSignature String?  @map("last_signature")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("indexer_state")
}
